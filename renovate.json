{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "packageRules": [
    {
      "description": "Auto-merge low-risk updates (digests, pins, minor, patch)",
      "matchUpdateTypes": ["digest", "pin", "minor", "patch"],
      "automerge": true
    }
  ],
  "helm-values": { "enabled": true },
  "github-actions": { "enabled": true }
}
